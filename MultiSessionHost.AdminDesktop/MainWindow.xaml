<Window x:Class="MultiSessionHost.AdminDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MultiSessionHost.AdminDesktop.ViewModels"
        Title="MultiSessionHost Admin Desktop"
        Width="1680"
        Height="1020"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:SessionOverviewViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Overview" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <UniformGrid Columns="3" Margin="0,0,0,12">
                        <Border BorderThickness="1" BorderBrush="#333" Padding="10" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Runtime Status" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding RuntimeStatus}"/>
                                <TextBlock Text="{Binding ActivityState}"/>
                            </StackPanel>
                        </Border>
                        <Border BorderThickness="1" BorderBrush="#333" Padding="10" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Policy" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PolicyState}"/>
                                <TextBlock Text="{Binding PolicyPausedText}"/>
                            </StackPanel>
                        </Border>
                        <Border BorderThickness="1" BorderBrush="#333" Padding="10" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Plan / Execution" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PlanStatus}"/>
                                <TextBlock Text="{Binding ExecutionStatus}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Start" Command="{Binding StartSessionCommand}" Margin="0,0,6,0"/>
                        <Button Content="Stop" Command="{Binding StopSessionCommand}" Margin="0,0,6,0"/>
                        <Button Content="Pause" Command="{Binding PauseSessionCommand}" Margin="0,0,6,0"/>
                        <Button Content="Resume" Command="{Binding ResumeSessionCommand}" Margin="0,0,6,0"/>
                        <Button Content="Pause Policy" Command="{Binding PausePolicyCommand}" Margin="0,0,6,0"/>
                        <Button Content="Resume Policy" Command="{Binding ResumePolicyCommand}" Margin="0,0,6,0"/>
                        <Button Content="Refresh UI" Command="{Binding RefreshUiCommand}" Margin="0,0,6,0"/>
                        <Button Content="Evaluate Plan" Command="{Binding EvaluatePlanCommand}" Margin="0,0,6,0"/>
                        <Button Content="Execute Plan" Command="{Binding ExecutePlanCommand}"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Highlights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TargetBindingViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Target &amp; Binding" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Text="Target Profile" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding TargetProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Variables" FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding Variables}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                    <Button Grid.Column="2" Content="Remove" Command="{Binding DataContext.RemoveVariableCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="Add Variable" Command="{Binding AddVariableCommand}" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <TextBlock Text="Overrides JSON" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding OverridesJson, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save" Command="{Binding SaveBindingCommand}" Margin="0,0,6,0"/>
                        <Button Content="Delete" Command="{Binding DeleteBindingCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="Resolved Target" FontWeight="SemiBold" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding ResolvedTargetText}" IsReadOnly="True" AcceptsReturn="True" Height="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:UiViewModel}">
            <TabControl Margin="8">
                <TabItem Header="Tree">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <TreeView ItemsSource="{Binding TreeNodes}" Grid.Column="0" Margin="0,0,8,0">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}"/>
                                        <TextBlock Text="  " />
                                        <TextBlock Text="{Binding Role}" Foreground="#777"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Metadata" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding MetadataText}" IsReadOnly="True" AcceptsReturn="True" Height="160" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>
                            <TextBlock Text="Planned Work Items" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding PlannedWorkItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Raw">
                    <TextBox Text="{Binding RawJson}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="8"/>
                </TabItem>
            </TabControl>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SemanticViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Semantic" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Summary" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <TextBlock Text="Alerts" FontWeight="SemiBold"/>
                    <ItemsControl ItemsSource="{Binding Alerts}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    <TextBlock Text="Lists" FontWeight="SemiBold" Margin="0,12,0,0"/>
                    <ItemsControl ItemsSource="{Binding Lists}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RiskViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Risk" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding Threats}"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DomainViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ActivityViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DecisionPlanViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DecisionExecutionViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MemoryViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PersistenceViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CommandsViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Commands" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Width="220" Text="{Binding NodeId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <ComboBox Width="160" ItemsSource="{Binding Kinds}" SelectedItem="{Binding SelectedKind}" Margin="0,0,8,0"/>
                        <TextBox Width="180" Text="{Binding ActionName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBox Width="180" Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBox Width="120" Text="{Binding SelectedValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <CheckBox Content="Bool" IsChecked="{Binding BoolValue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="Send" Command="{Binding SendCommandCommand}"/>
                    </StackPanel>
                    <TextBox Text="{Binding ResultText}" IsReadOnly="True" AcceptsReturn="True" Height="180" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TargetsCatalogViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:BindingsCatalogViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CoordinationViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PolicyRulesViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PolicyControlViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBox Text="{Binding RawText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="12"/></ScrollViewer>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#1e1f22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#25272b" Padding="12">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Admin API" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="360" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <Button Content="Connect" Command="{Binding ConnectCommand}" Margin="0,0,8,0"/>
                    <ToggleButton Content="Auto Refresh" IsChecked="{Binding IsAutoRefreshEnabled}" Margin="0,0,8,0"/>
                    <TextBlock Text="Interval (sec)" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="60" Text="{Binding RefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <Button Content="Refresh Now" Command="{Binding RefreshNowCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastRefreshText}" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2a2d31" Padding="12" Margin="0,0,12,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Sessions" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SessionSearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox Width="140" ItemsSource="{Binding RuntimeStatusOptions}" SelectedItem="{Binding SelectedRuntimeStatus}" Margin="0,0,8,0"/>
                            <ComboBox Width="120" ItemsSource="{Binding PolicyPausedOptions}" SelectedItem="{Binding SelectedPolicyPaused}" Margin="0,0,8,0"/>
                            <ComboBox Width="140" ItemsSource="{Binding ActivityStateOptions}" SelectedItem="{Binding SelectedActivityState}"/>
                        </StackPanel>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding SessionsView}" SelectedItem="{Binding SelectedSession}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False" Background="#1f2124" Foreground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Session" Binding="{Binding SessionId}" Width="*"/>
                            <DataGridTextColumn Header="Display" Binding="{Binding DisplayName}" Width="*"/>
                            <DataGridTextColumn Header="Runtime" Binding="{Binding RuntimeStatus}" Width="110"/>
                            <DataGridTextColumn Header="Policy" Binding="{Binding PolicyPausedText}" Width="90"/>
                            <DataGridTextColumn Header="Activity" Binding="{Binding ActivityState}" Width="100"/>
                            <DataGridTextColumn Header="Plan" Binding="{Binding PlanStatus}" Width="100"/>
                            <DataGridTextColumn Header="Exec" Binding="{Binding ExecutionStatus}" Width="100"/>
                            <DataGridTextColumn Header="Risk" Binding="{Binding ThreatSeverity}" Width="80"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetProfile}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#2a2d31" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="280"/>
                    </Grid.RowDefinitions>
                    <TabControl Grid.Row="0" ItemsSource="{Binding SessionTabs}" SelectedItem="{Binding SelectedSessionTab}" Margin="0,0,0,8">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}"/>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                    <TabControl Grid.Row="1" ItemsSource="{Binding GlobalTabs}" SelectedItem="{Binding SelectedGlobalTab}">
                        <TabControl.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding Title}"/></DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate><ContentControl Content="{Binding}"/></DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#25272b" Padding="8">
            <DockPanel>
                <TextBlock Text="{Binding SelectedSessionText}" Foreground="White" DockPanel.Dock="Left" Margin="0,0,16,0"/>
                <TextBlock Text="{Binding ErrorText}" Foreground="#ff8080"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
